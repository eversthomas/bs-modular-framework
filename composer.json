{
  "name": "bs/modular-framework",
  "description": "BS_Modular-Framework – tabellenbasiertes Datenframework als WordPress-Plugin.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "autoload": {
    "psr-4": {
      "BS\\\\ModularFramework\\\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BS\\\\ModularFramework\\\\Tests\\\\": "tests/php/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "test": "phpunit"
  }
}

